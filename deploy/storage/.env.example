# Copy to .env with mode 0600. setup-storage-server.sh creates strong random
# values automatically when .env does not exist.
CHERRY_DATA_ROOT=/srv/cherry
CHERRY_API_PORT=5070
CHERRY_WEB_PORT=80
POSTGRES_DB=cherry
POSTGRES_USER=cherry
POSTGRES_PASSWORD=replace-with-random-secret
CHERRY_API_KEY=replace-with-random-secret
MEILI_MASTER_KEY=replace-with-random-secret-at-least-16-bytes
# Each value is Base64 of the distinct >=32-byte raw transport HMAC installed
# only on the matching crawler. These keys must never be shared across regions.
CHERRY_HEAT_CRAWLER_0_SECRET_BASE64=replace-with-base64-secret-for-crawler-0
CHERRY_HEAT_CRAWLER_1_SECRET_BASE64=replace-with-base64-secret-for-crawler-1
# Storage-only key that re-pseudonymizes rolling actors before daily storage.
CHERRY_HEAT_DAILY_ACTOR_SECRET_BASE64=replace-with-distinct-base64-secret
# First UTC day whose two-crawler completeness is expected (YYYY-MM-DD).
CHERRY_HEAT_COVERAGE_START_DAY=YYYY-MM-DD
CHERRY_HEAT_CRAWLER_0=sg-crawler-01
CHERRY_HEAT_CRAWLER_1=jp-crawler-01
CHERRY_HEAT_LATE_GRACE_MINUTES=30

# Measurement variables, not final declarations. Change one at a time and
# record the corpus/config checksum in the storage/search ledger.
MEILI_OUTBOX_BATCH_SIZE=500
MEILI_OUTBOX_LEASE_SECONDS=300
MEILI_TASK_POLL_MS=250
MEILI_TASK_TIMEOUT_SECONDS=120
MEILI_OUTBOX_IDLE_MS=2000
CHERRY_DEDUP_CAPACITY=30000000
CHERRY_HEAT_COMMIT_BATCH_REQUESTS=8
CHERRY_HEAT_PROJECTION_BATCH_SIZE=500
CHERRY_HEAT_ROLLING_MAX_BYTES=5368709120
CHERRY_HEAT_ROLLING_MIN_FREE_BYTES=2147483648
