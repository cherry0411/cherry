# Root-only file installed as /etc/cherry-backup.env. The named remote MUST be
# type = crypt; point that crypt remote at an off-host provider or account.
CHERRY_BACKUP_REMOTE=replace-with-crypt-remote:cherry-storage
CHERRY_RCLONE_CONFIG=/etc/rclone/cherry.conf
# Contains only the SHA-256 of the exact rclone config after that config has
# been escrowed outside both this host and its backup provider account.
CHERRY_RCLONE_ESCROW_MARKER=/etc/cherry-rclone-key-escrowed
CHERRY_BACKUP_HOST_ID=replace-with-stable-storage-host-id
CHERRY_REPO_DIR=/opt/cherry
CHERRY_DATA_ROOT=/srv/cherry

# A weekly base backup plus continuous compressed WAL. Six bases span roughly
# five weeks; WAL is kept longer so the oldest retained base remains usable.
CHERRY_BACKUP_KEEP_BASES=6
CHERRY_BACKUP_WAL_RETENTION_DAYS=50
CHERRY_BACKUP_LOCAL_WAL_HOURS=24
CHERRY_BACKUP_PG_MAX_RATE=64M
