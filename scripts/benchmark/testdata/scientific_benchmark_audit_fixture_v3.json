{
  "schema_version": 3,
  "name": "eligible-two-arm-block",
  "network": {
    "node_ids": 96,
    "udp_port_start": 21000,
    "udp_port_end": 21095,
    "sink_tcp_port": 5080
  },
  "design": {
    "plan": "AB",
    "warmup_runtime_rows": 20,
    "measurement_runtime_rows": 10
  },
  "runtime_line": "runtime 30s: dht_recv=100 handled=100 dropped=0 refresh_q=10 lookup_sent=20 paused=false wire_q_drop=0 ann_q=10000",
