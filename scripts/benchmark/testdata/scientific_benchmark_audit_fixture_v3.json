    "primary": {"global_unique_per_second": 40.0},
    "peer_source_funnel": {"announce_queued": 100000},
    "local_funnel": {"wire_queue_dropped": 0, "wire_download_ok": 900},
    "discovery": {"active_lookup_sent": 10000, "refresh_queries": 2000},
    "resources": {
      "udp_rcvbuf_errors": 0,
      "udp_sndbuf_errors": 0,
      "tx_qdisc_drops": 0,
      "rss_mb_max": 1000,
      "cpu_pct_mean": 120
    }
  }
