    {"kind": "sampler_end", "success": true, "runtime_windows": 30}
  ],
  "result": {
    "runtime_windows": 10,
    "health": {
      "monitor_samples": 10,
      "oracle_samples_valid": 10,
      "oracle_sample_coverage": 1.0,
      "oracle_samples_rejected": 0,
      "runtime_window_coverage": 1.0
