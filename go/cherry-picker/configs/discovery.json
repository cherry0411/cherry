{
  "role": "discovery",
  "instance_id": "discovery-1",
  "listen_addr": ":20001",
  "event_queue": 8192,
  "dedupe": {
    "peer_ttl": "10m",
    "metadata_ttl": "30m"
  },
  "discovery": {
    "mode": "crawl",
    "emit_peer_events": true
  },
  "metadata": {
    "enabled": false,
    "black_list_size": 65536,
    "request_queue_size": 4096,
    "worker_queue_size": 256
  },
  "exporter": {
    "kind": "file",
    "file_path": "events-discovery.jsonl",
    "batch_size": 256,
    "flush_interval": "2s",
    "http_timeout": "5s",
    "http_retries": 3,
    "retry_backoff": "1s"
  }
}